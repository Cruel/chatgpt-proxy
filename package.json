{
  "name": "chatgpt-playwright-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "Local single-user HTTP proxy for a persistent Playwright-controlled ChatGPT session",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "cgpt": "./dist/cli/main.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./api": "./dist/api/index.js",
    "./browser": "./dist/browser/index.js",
    "./cli": "./dist/cli/index.js",
    "./config": "./dist/config/index.js",
    "./db": "./dist/db/index.js",
    "./domain": "./dist/domain/index.js",
    "./runtime": "./dist/runtime.js",
    "./scheduler": "./dist/scheduler/index.js",
    "./service": "./dist/service/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "browser:install": "playwright install chromium",
    "browser:install:with-deps": "playwright install --with-deps chromium",
    "browser:install:chrome": "playwright install chrome",
    "auth": "tsx scripts/bootstrap-browser-profile.ts",
    "fixture:import": "tsx scripts/import-diagnostic-fixture.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:browser-fixtures",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:browser-fixtures": "playwright test --config playwright.config.ts",
    "test:ci": "pnpm typecheck && pnpm lint && pnpm test",
    "test:live": "tsx scripts/run-live-tests.ts",
    "test:live:delete": "tsx scripts/run-live-tests.ts --delete",
    "acceptance:live": "tsx scripts/run-live-tests.ts --acceptance",
    "cli": "tsx src/cli/main.ts",
    "server:fake": "tsx src/server-main.ts",
    "server": "node --import tsx src/playwright-server-main.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "fastify": "^5.10.0",
    "pino": "^10.3.1",
    "playwright": "^1.61.1",
    "smol-toml": "^1.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
